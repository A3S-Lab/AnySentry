{
  "name": "@a3s-lab/anysentry",
  "version": "0.1.0",
  "private": true,
  "description": "AnySentry — universal agent observability / monitoring / intervention, built on a3s-sentry.",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @anysentry/api dev",
    "dev:web": "pnpm --filter @anysentry/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @anysentry/api build",
    "build:web": "pnpm --filter @anysentry/web build",
    "verify:deployment-manifests": "node scripts/verify-deployment-manifests.mjs",
    "verify:progressive-api": "pnpm verify:ai-native-api",
    "verify:progressive-api:local": "pnpm verify:ai-native-api:local",
    "verify:ai-native-api": "node scripts/verify-ai-native-api.mjs",
    "verify:ai-native-api:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-ai-native-api.mjs",
    "verify:management-auth": "node scripts/verify-management-auth.mjs",
    "verify:management-auth:local": "pnpm build:api && ANYSENTRY_ADMIN_TOKEN=verify-admin-token node scripts/verify-deep-links-local.mjs scripts/verify-management-auth.mjs",
    "verify:deep-links": "node scripts/verify-deep-links.mjs",
    "verify:deep-links:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs",
    "verify:dashboard-runtime": "node scripts/verify-dashboard-runtime.mjs",
    "verify:dashboard-runtime:local": "pnpm build && node scripts/verify-deep-links-local.mjs scripts/verify-dashboard-runtime.mjs",
    "verify:dashboard-runtime:base-path:local": "PUBLIC_BASE_PATH=/apps/anysentry pnpm verify:dashboard-runtime:local",
    "verify:coverage-runtime": "node scripts/verify-coverage-runtime.mjs",
    "verify:coverage-runtime:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-coverage-runtime.mjs",
    "verify:ingest-protocols": "node scripts/verify-ingest-protocols.mjs",
    "verify:ingest-protocols:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-ingest-protocols.mjs",
    "verify:observer-ingest": "node scripts/verify-observer-ingest.mjs",
    "verify:observer-ingest:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-observer-ingest.mjs",
    "verify:forwarders": "node scripts/verify-forwarders.mjs",
    "verify:forwarders:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-forwarders.mjs",
    "verify:operations-lifecycle": "node scripts/verify-operations-lifecycle.mjs",
    "verify:operations-lifecycle:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-operations-lifecycle.mjs",
    "verify:objectives-runtime": "node scripts/verify-objectives-runtime.mjs",
    "verify:objectives-runtime:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-objectives-runtime.mjs",
    "verify:maintenance-runtime": "node scripts/verify-maintenance-runtime.mjs",
    "verify:maintenance-runtime:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-maintenance-runtime.mjs",
    "verify:remediation-runtime": "node scripts/verify-remediation-runtime.mjs",
    "verify:remediation-runtime:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-remediation-runtime.mjs",
    "verify:evidence-bundle": "node scripts/verify-evidence-bundle.mjs",
    "verify:evidence-bundle:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-evidence-bundle.mjs",
    "verify:notification-dispatch": "node scripts/verify-notification-dispatch.mjs",
    "verify:notification-dispatch:local": "pnpm build:api && node scripts/verify-deep-links-local.mjs scripts/verify-notification-dispatch.mjs",
    "verify:contracts:local": "pnpm verify:deployment-manifests && pnpm verify:progressive-api:local && pnpm verify:management-auth:local && pnpm verify:dashboard-runtime:base-path:local && pnpm build && ANYSENTRY_ADMIN_TOKEN= ANYSENTRY_MANAGEMENT_TOKEN= node scripts/verify-deep-links-local.mjs scripts/verify-dashboard-runtime.mjs scripts/verify-coverage-runtime.mjs scripts/verify-forwarders.mjs scripts/verify-observer-ingest.mjs scripts/verify-ingest-protocols.mjs scripts/verify-ai-native-api.mjs scripts/verify-operations-lifecycle.mjs scripts/verify-objectives-runtime.mjs scripts/verify-maintenance-runtime.mjs scripts/verify-remediation-runtime.mjs scripts/verify-evidence-bundle.mjs scripts/verify-notification-dispatch.mjs scripts/verify-deep-links.mjs"
  }
}
