# AnySentry configuration — copy to `.env` and edit. All values have safe defaults.

# --- HTTP ---
PORT=29653                                   # dashboard + API + /ingest

# --- ClickHouse (durable event store) ---
# If CLICKHOUSE_URL is unset, AnySentry runs in-memory only (no durability across restarts).
CLICKHOUSE_URL=http://clickhouse:8123        # standalone (no compose): http://localhost:8123
CLICKHOUSE_DB=anysentry
CLICKHOUSE_USER=anysentry
CLICKHOUSE_PASSWORD=anysentry

# --- Event sources / enrichment (optional) ---
# Comma-separated host/IP list; agent→endpoint connections to these are surfaced as LLM calls.
# ANYSENTRY_LLM_ENDPOINTS=api.openai.com,api.anthropic.com,api.deepseek.com

# --- Alerting (optional, platform-side only) ---
# ANYSENTRY_ALERTS=on
# ANYSENTRY_ALERT_WEBHOOK_URL=https://example.com/anysentry-alerts
# ANYSENTRY_ALERT_WEBHOOK_COOLDOWN_SECS=300
# ANYSENTRY_ALERT_INCIDENT_MIN_SEVERITY=high
# ANYSENTRY_ALERT_EVENT_MIN_SEVERITY=critical
# ANYSENTRY_ALERT_AGENT_OPEN_INCIDENT_THRESHOLD=3
# ANYSENTRY_COLLECTOR_STALE_AFTER_SECS=180
# ANYSENTRY_COLLECTOR_DOWN_AFTER_SECS=600
# ANYSENTRY_SOURCE_STALE_AFTER_SECS=600
# ANYSENTRY_SOURCE_DOWN_AFTER_SECS=1800
# ANYSENTRY_SOURCE_TOKEN_ROTATION_DAYS=90
# ANYSENTRY_REMEDIATION_OVERDUE_SCAN_SECS=60

# --- Management API auth (optional) ---
# When set, control-plane mutations such as policy saves, Source management, Incident/Alert updates,
# Maintenance windows, Notification routes, Objectives, and Remediation edits require this token.
# Read APIs and producer paths (/ingest, Collector heartbeat, Source check-in) keep using their own
# Source tokens and remain separate from management auth.
# ANYSENTRY_ADMIN_TOKEN=change-me-long-random-token

# --- Kubernetes identity enrichment ---
# Auto-enabled when running in-cluster (resolves pod-uid -> real agent name via the K8s API); a no-op
# standalone. Set =off to disable it even in-cluster.
# ANYSENTRY_KUBE_ENRICH=off
# ANYSENTRY_AGENT_NAMESPACES=default          # comma-separated namespaces to read pods from

# --- Demo ---
# ANYSENTRY_SYNTHETIC_FEED=on                 # self-driving demo load (still really judged)

# --- Forwarder (scripts/observer-forward.js) ---
# ANYSENTRY_INGEST_URL=http://localhost:29653/security-center/ingest
# A3S_OBSERVER_COLLECTOR_ID=node-a             # attached to forwarded events; observer also emits CollectorHeartbeat
# A3S_NODE_NAME=node-a
# ANYSENTRY_SOURCE_ID=src_xxx                  # optional: created in /sources
# ANYSENTRY_SOURCE_NAME=node-a-observer
# ANYSENTRY_SOURCE_TYPE=observer               # observer | forwarder | webhook | otel | custom
# ANYSENTRY_INGEST_TOKEN=ansrc_xxx             # optional: source token, only shown when created/rotated
# ANYSENTRY_HEARTBEAT_SECS=30                  # set 0 to disable forwarder self-heartbeats
# ANYSENTRY_HEARTBEAT_URL=http://localhost:29653/security-center/collectors/heartbeat
